# =========================================================
# HAKS SHOP - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# =========================================================

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-this-in-production
FLASK_ENV=production

# Database Configuration
# Get this from your Render PostgreSQL service or other provider
DATABASE_URL=postgresql://user:password@host:port/database

# Redis Configuration (Optional - for caching and rate limiting)
# Get this from Render Redis addon or Redis Cloud
REDIS_URL=redis://default:password@host:port

# Server Configuration
PORT=5000

# JWT Configuration
JWT_EXPIRATION_HOURS=24

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:3000

# Admin Configuration
ADMIN_EMAIL=admin@haksshop.com
ADMIN_PASSWORD=change-this-secure-password

# Email Configuration (for order confirmations - optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Payment Gateway (optional)
# RAZORPAY_KEY_ID=your-razorpay-key
# RAZORPAY_KEY_SECRET=your-razorpay-secret

# File Upload (optional)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Monitoring & Logging (optional)
# SENTRY_DSN=your-sentry-dsn
# LOG_LEVEL=INFO
